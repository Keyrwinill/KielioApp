@*
    20251115    Initial -- Sidebar/Image tab/Deutsch tab
    20251122    Deutsch Verb
    20260104    Create Parent "Language" and Mood Person setting
    20260303    Seperate CSS by page and move sidebar to _SidebarMenu.cshtml
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KielioApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <!-- CSS refers to wwwroot/site.css -->
		@await Html.PartialAsync("_SidebarMenu")
        <div class="d-flex flex-column p-3 flex-grow-1">
            <main class="content p-3 flex-grow-1">
                @RenderBody()
            </main>
            <footer class="footer">
                <p>&copy; 2026 - Kielio</p>
            </footer>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
