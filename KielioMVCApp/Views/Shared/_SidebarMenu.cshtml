@*
    20260303    Initial: move sidebar from _Layout.cshtml
*@
<div class="sidebar">
    <div class="top-row ps-3 navbar navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="">Kielio</a>
        </div>
    </div>
    <div class="nav-scrollable">
        <nav class="nav flex-column">
            <div class="nav-item">
                <a class="nav-link px-3" href="/">Home</a>
            </div>
            <!-- Parent menu with collapsible children -->
            <div class="nav-item">
                <a class="nav-link"
                   data-bs-toggle="collapse"
                   data-bs-target="#collapseLanguage"
                   aria-expanded="false" ,
                   aria-controls="collapseLanguage">
                    Language
                </a>
                <div class="collapse" id="collapseLanguage">
                    <nav class="nav flex-column ms-3">
                        <div class="nav-item">
                            <a class="nav-link" href="/Language/MoodSetting">Mood Setting</a>
                        </div>
                        <div class="nav-item">
                            <a class="nav-link"
                               data-bs-toggle="collapse"
                               data-bs-target="#collapseDeutsch"
                               aria-expanded="false" ,
                               aria-controls="collapseDeutsch">
                                Deutsch
                            </a>
                            <div class="collapse" id="collapseDeutsch">
                                <nav class="nav flex-column ms-3">
                                    <div class="nav-item">
                                        <a class="nav-link" href="/Language/Deutsch/Conjugation">Deutsch Verb</a>
                                    </div>
                                    <div class="nav-item">
                                        <a class="nav-link" href="/Language/Deutsch/Adjective">Deutsch Adjective</a>
                                    </div>
                                </nav>
                            </div>
                        </div>
                        <div class="nav-item">
                            <a class="nav-link"
                               data-bs-toggle="collapse"
                               data-bs-target="#collapseFrançais"
                               aria-expanded="false" ,
                               aria-controls="collapseFrançais">
                                Français
                            </a>
                            <div class="collapse" id="collapseFrançais">
                                <nav class="nav flex-column ms-3">
                                    <div class="nav-item">
                                        <a class="nav-link" href="/Language/Deutsch/Verb">Français Verb</a>
                                    </div>
                                </nav>
                            </div>
                        </div>
                    </nav>
                </div>
            </div>
            <div class="nav-item">
                <a class="nav-link"
                   data-bs-toggle="collapse"
                   data-bs-target="#collapseImage"
                   aria-expanded="@(IsImageSectionActive() ? "true" : "false")"
                   aria-controls="collapseImage">
                    Image
                </a>
                <div class="collapse @(IsImageSectionActive() ? "show" : "")" id="collapseImage">
                    <nav class="nav flex-column ms-3">
                        <div class="nav-item">
                            <a class="nav-link @(IsActivePage("/Image/Blur") ? "active" : "")" href="/Image/Blur">Image Blurring</a>
                        </div>
                    </nav>
                </div>
            </div>
        </nav>
    </div>   
</div>
@functions {
    // Returns true if current page is under the Image section
    bool IsImageSectionActive()
    {
        var path = Context.Request.Path.Value?.ToLower();
        return path != null && path.StartsWith("/image");
    }

    // Returns true if current page matches the given path
    bool IsActivePage(string pagePath)
    {
        var path = Context.Request.Path.Value?.ToLower();
        return path == pagePath.ToLower();
    }
}
